APP_NAME="Garda Lake Rentals"
APP_ENV=production
APP_KEY=base64:Tc/q5EUoQ2XkK5Sl34TtsdVOUoi0ufRmMuJ8kVRyGeI=
APP_DEBUG=true
APP_URL=https://lakegardarentals.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=wrqfycsvxn
DB_USERNAME=wrqfycsvxn
DB_PASSWORD=f79jdH8M57

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# local (macOS/Linux): "background" runs jobs in a separate PHP process—no `php artisan queue:work` needed. Production: "database" or "redis" with a real worker.
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Admin image uploads (KB). 20480 = 20 MB. Ensure PHP upload_max_filesize / post_max_size are not lower.
ADMIN_IMAGE_MAX_KB=20480

VITE_APP_NAME="${APP_NAME}"

# OpenAI (optional): auto-translates English CMS copy to stored German/Italian (save + backfill + admin "Translate" button)
# Paste your secret key from https://platform.openai.com — never commit real keys; copy this file to .env and fill in.
OPENAI_API_KEY=
OPENAI_TRANSLATION_MODEL=gpt-5.4-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_REQUEST_TIMEOUT=300
# Translations are queued; keep `QUEUE_CONNECTION=database` and run a worker: `php artisan queue:work`, or `npm run dev:all` (Vite + serve + queue).
