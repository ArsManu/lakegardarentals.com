APP_NAME="Lake Garda Rentals"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

# SQLite (default) or MySQL
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=lake_garda
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
QUEUE_CONNECTION=database

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Inquiry emails (defaults to MAIL_FROM_ADDRESS)
INQUIRY_NOTIFY_EMAIL=

# Public site (config/lakegarda.php)
SITE_NAME="Lake Garda Rentals"
SITE_PHONE="+393331112233"
SITE_PHONE_DISPLAY="+39 333 111 2233"
SITE_EMAIL="info@example.com"
WHATSAPP_NUMBER=
SITE_ADDRESS="Garda (VR), Lake Garda, Italy"
MAP_EMBED_URL=
BUSINESS_LAT=
BUSINESS_LNG=

# Admin user (seeded)
ADMIN_EMAIL=admin@lakegardarentals.local
ADMIN_PASSWORD=changeme

# Max admin image upload size in kilobytes (match PHP upload_max_filesize / post_max_size)
# ADMIN_IMAGE_MAX_KB=20480

# Bulk gallery uploads: PHP cannot raise post_max_size at runtime.
# Local dev: use `composer run serve` (sets post_max_size=256M) or see php-dev.ini in the project root.
# Production: raise post_max_size, upload_max_filesize, and nginx client_max_body_size above your largest batch.

VITE_APP_NAME="${APP_NAME}"
